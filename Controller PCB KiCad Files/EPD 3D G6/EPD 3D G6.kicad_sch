	(text "XL6009 output:\n  [ ] 470uF 35V electrolytic\n  [ ] 470-1000uF 35V electrolytic (extra)\n  [ ] 100nF ceramic\nESP32 3V3 supply:\n  [ ] 10uF\n  [ ] 100nF ceramic\nPer TMC2209 x3:\n  [ ] 100uF electrolytic on VM\n  [ ] 100nF ceramic on VM\n  [ ] 100nF ceramic on VIO\nFSR front-end x4:\n  [ ] 10k pull-down\n  [ ] 1k series\n  [ ] 100nF at ADC pin\nBattery sense:\n  [ ] 100k + 100k divider\nUser interface:\n  [ ] 10k pull-down for CONN_DETECT\n  [ ] Optional 100nF across mode button"
		(exclude_from_sim no)
		(at 14.732 250.19 0)
		(effects
			(font
				(size 1 1)
			)
			(justify left top)
		)
		(uuid "cbb5885d-cc6c-4eed-b7bf-add217989532")
	)
	(text "JUMPER PINS\n"
		(exclude_from_sim no)
		(at 180.848 134.874 0)
		(effects
