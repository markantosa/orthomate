(text "4-pin header J_OLED:\n  Pin1: VCC <- 3V3\n  Pin2: GND\n  Pin3: SDA <- OLED_SDA (GPIO22)\n  Pin4: SCL <- OLED_SCL (GPIO23)\nI2C address: 0x3C (verify on module)\nKeep traces short, away from boost zone"
(exclude_from_sim no)
(at 115 138 0)
(effects
