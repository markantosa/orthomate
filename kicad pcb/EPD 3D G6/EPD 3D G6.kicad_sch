(text "Per channel FSR1-FSR4:\n  3V3\n   |\n  FSR (off-board via J_MAIN pins 5-8)\n   |\n   +-- R_S = 1k --> FSRx_ADC (GPIOx)\n   |                      |\n  R_D = 10k            C=100nF -> GND\n   |\n  GND\n\nFSR1 J_MAIN pin5 -> GPIO0\nFSR2 J_MAIN pin6 -> GPIO1\nFSR3 J_MAIN pin7 -> GPIO2\nFSR4 J_MAIN pin8 -> GPIO3\nAll FSR supply from 3V3 ONLY"
(exclude_from_sim no)
(at 3 64 0)
(effects
(font
(size 1 1)
)
(justify left top)
)
(uuid "32cac2e4-9535-4f4a-8637-55abfe4a9f74")
)

