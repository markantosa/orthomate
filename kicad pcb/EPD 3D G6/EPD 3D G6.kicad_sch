(text "Power: VIN <- 5V_SYS   GND\nOutput: 3V3 -> 3V3 net\nGPIO0  FSR1_ADC\nGPIO1  FSR2_ADC\nGPIO2  FSR3_ADC\nGPIO3  FSR4_ADC\nGPIO4  STEPPER_ENN\nGPIO5  VBAT_SENSE\nGPIO6  ACT1_STEP\nGPIO7  ACT1_DIR\nGPIO9  CONN_DETECT\nGPIO12 ACT2_STEP\nGPIO13 ACT2_DIR\nGPIO14 MODE_BTN\nGPIO20 ACT3_STEP\nGPIO21 ACT3_DIR\nGPIO22 OLED_SDA\nGPIO23 OLED_SCL\nAVOID: GPIO8, GPIO10, GPIO11, GPIO15, USB"
(exclude_from_sim no)
(at 115 6 0)
