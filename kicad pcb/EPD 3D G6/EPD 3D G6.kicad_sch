)
(text "VBAT -- R1=100k --+-- VBAT_SENSE -> GPIO5\n                   |\n                  R2=100k\n                   |\n                  GND\nFirmware: ADC reads ~VBAT/2, scales x2\n< 3.5V = warn   < 3.35V = disable motors\n< 3.2V = shutdown"
(exclude_from_sim no)
(at 57 64 0)
