  (rectangle (start 272 2) (end 360 190)
    (stroke (width 0.2) (type default)) (fill (type none)))
  (text "BLOCK 9 - J_MAIN (20-PIN INSOLE CONNECTOR)" (at 273 3 0)
    (effects (font (size 1.5 1.5) bold) (justify left)))
  (text "Pin  Net           Dir\n  1  3V3_SENSE     -> insole (connector detect)\n  2  5V_SYS        -> insole\n  3  GND\n  4  GND           (duplicate return)\n  5  FSR1_RAW      <- sensor\n  6  FSR2_RAW      <- sensor\n  7  FSR3_RAW      <- sensor\n  8  FSR4_RAW      <- sensor\n  9  ACT1_OA1      -> coil\n 10  ACT1_OA2      -> coil\n 11  ACT1_OB1      -> coil\n 12  ACT1_OB2      -> coil\n 13  ACT2_OA1      -> coil\n 14  ACT2_OA2      -> coil\n 15  ACT2_OB1      -> coil\n 16  ACT2_OB2      -> coil\n 17  ACT3_OA1      -> coil\n 18  ACT3_OA2      -> coil\n 19  ACT3_OB1      -> coil\n 20  ACT3_OB2      -> coil\n\nDual GND pins mandatory for motor return current\nConnector: IDC / Molex / screw terminal" (at 273 6 0)
    (effects (font (size 1.0 1.0)) (justify left top)))

  (rectangle (start 114 194) (end 268 250)
    (stroke (width 0.35) (type dash)) (fill (type none)))
  (text "PIN MAP - DO NOT CHANGE WITHOUT LAYOUT REVIEW" (at 115 195 0)
    (effects (font (size 1.5 1.5) bold) (justify left)))
  (text "GPIO0  = FSR1_METATARSAL (ADC)\nGPIO1  = FSR2_ARCH (ADC)\nGPIO2  = FSR3_CALCANEUS (ADC)\nGPIO3  = FSR4_AUX (ADC)\nGPIO4  = STEPPER_ENN (active LOW)\nGPIO5  = VBAT_SENSE (ADC - 1:2 divider)\nGPIO6  = ACT1_STEP\nGPIO7  = ACT1_DIR\nGPIO9  = CONN_DETECT (INPUT_PULLDOWN)\nGPIO12 = ACT2_STEP\nGPIO13 = ACT2_DIR\nGPIO14 = MODE_BUTTON (INPUT_PULLUP)\nGPIO20 = ACT3_STEP\nGPIO21 = ACT3_DIR\nGPIO22 = OLED_SDA\nGPIO23 = OLED_SCL\nAVOID: GPIO8 (RGB LED)  GPIO10/11 (not broken out)\n       GPIO15 (boot strap)  USB pins" (at 115 198 0)
    (effects (font (size 1.0 1.0)) (justify left top)))

  (rectangle (start 272 194) (end 420 250)
    (stroke (width 0.35) (type dash)) (fill (type none)))
  (text "ENGINEERING NOTES" (at 273 195 0)
    (effects (font (size 1.5 1.5) bold) (justify left)))
  (text "POWER:\n  ESP32 powered from 5V_SYS ONLY - never directly from LiPo\n  Charging and actuation MUTUALLY EXCLUSIVE\n  Firmware disables STEPPER_ENN on USB/charge detect\n\nLAYOUT (single-layer PCB - jumpers allowed):\n  Zone A (LEFT):   LiPo, TP4056, XL6009, bulk caps\n  Zone B (CENTRE): TMC2209, motor output traces\n  Zone C (RIGHT):  ESP32, FSR, OLED - farthest from boost\n  NEVER route motor return current through analog ground\n  Trunk+branch ground topology (battery-neg = origin)\n\nTRACE WIDTHS:\n  Power/GND: 1.5-2.0mm   Motor: 0.8-1.2mm\n  Digital: 0.25-0.4mm    Analog/I2C: 0.25-0.4mm\n\nFIRMWARE RULES:\n  Never start all 3 motors simultaneously (stagger 50-100ms)\n  Sample FSR only when motors idle or use median filter x5\n  OLED update rate <= 10Hz during actuation\n  Expose PDN_UART and DIAG pads per TMC2209\n  USB port on ESP32 and TP4056 must remain accessible" (at 273 198 0)
    (effects (font (size 1.0 1.0)) (justify left top)))

  (rectangle (start 2 234) (end 108 290)
    (stroke (width 0.35) (type dash)) (fill (type none)))
  (text "PASSIVES CHECKLIST" (at 3 235 0)
    (effects (font (size 1.5 1.5) bold) (justify left)))
  (text "XL6009 output:\n  [ ] 470uF 35V electrolytic\n  [ ] 470-1000uF 35V electrolytic (extra)\n  [ ] 100nF ceramic\nESP32 3V3 supply:\n  [ ] 10uF\n  [ ] 100nF ceramic\nPer TMC2209 x3:\n  [ ] 100uF electrolytic on VM\n  [ ] 100nF ceramic on VM\n  [ ] 100nF ceramic on VIO\nFSR front-end x4:\n  [ ] 10k pull-down\n  [ ] 1k series\n  [ ] 100nF at ADC pin\nBattery sense:\n  [ ] 100k + 100k divider\nUser interface:\n  [ ] 10k pull-down for CONN_DETECT\n  [ ] Optional 100nF across mode button" (at 3 238 0)
    (effects (font (size 1.0 1.0)) (justify left top)))

